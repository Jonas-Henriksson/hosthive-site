---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Affiliate Disclosure" description="HostHive affiliate disclosure.">
  <div class="container"><div class="lp">
    <h1>Affiliate Disclosure</h1><p class="u">Last updated: April 2026</p>
    <section><h2>How We Earn Revenue</h2><p>HostHive participates in affiliate programs with Bluehost, SiteGround, Hostinger, Cloudways, WP Engine, Kinsta, and other hosting providers. We earn commissions when you purchase through our links at no extra cost to you.</p></section>
    <section><h2>Editorial Independence</h2><p>Commissions never influence reviews or ratings. Our team tests every provider independently. We include both pros and cons in every review.</p></section>
    <section><h2>Our Testing</h2><p>Every host undergoes uptime monitoring, speed benchmarking, support evaluation, and feature analysis. We re-test regularly to keep reviews current.</p></section>
    <section><h2>Questions?</h2><p>Email <a href="mailto:info@hosthive.net">info@hosthive.net</a>.</p></section>
  </div></div>
</BaseLayout>
<style>.lp{max-width:700px;margin:0 auto;padding:3rem 0}.lp h1{font-size:2.5rem;margin-bottom:.5rem}.u{color:#6b7280;font-size:.9rem;margin-bottom:2rem}.lp section{margin-bottom:2rem}.lp h2{font-size:1.3rem;margin-bottom:.75rem;color:#f59e0b}.lp p{color:#d1d8e0;line-height:1.8}</style>
