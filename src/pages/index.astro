---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import siteConfig from '../site.config';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = [...allArticles].sort((a, b) => {
  const scoreA = a.data.score || 0;
  const scoreB = b.data.score || 0;
  if (scoreB !== scoreA) return scoreB - scoreA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

const latestArticles = [...allArticles]
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 8);

const TOP_PICKS = [
  { name: 'Kinsta', price: '$35/mo', category: 'Managed WordPress', slug: 'kinsta', tag: "Editor's Pick" },
  { name: 'Cloudways', price: '$14/mo', category: 'Cloud Hosting', slug: 'cloudways', tag: null },
  { name: 'WP Engine', price: '$25/mo', category: 'WordPress Hosting', slug: 'wpengine', tag: null },
  { name: 'Bluehost', price: '$2.95/mo', category: 'Shared Hosting', slug: 'bluehost', tag: 'Best Value' },
  { name: 'Contabo', price: '$6.99/mo', category: 'VPS Hosting', slug: 'contabo', tag: null },
  { name: 'Hostinger', price: '$2.99/mo', category: 'Shared Hosting', slug: 'hostinger', tag: null },
];

const featuredArticle = sortedArticles[0];
const rankedArticles = sortedArticles.slice(1, 7);
const remainingArticles = sortedArticles.slice(7);

const API_URL = 'https://newsletter.host-hive.net/subscribe';
const SITE_ID = 'hosthive';
const fGradient = 'linear-gradient(135deg, #4c1d95, #7c3aed)';
---

<BaseLayout title={`${siteConfig.siteName} — ${siteConfig.tagline}`}>
  <div class="three-col-wrapper">

    <!-- ── LEFT COLUMN: Latest Reviews ─────────────── -->
    <aside class="col-left">
      <div class="panel-header">
        <span class="panel-label">Latest Reviews</span>
      </div>
      <ul class="latest-list">
        {latestArticles.map((article) => (
          <li class="latest-item">
            <a href={`/${article.slug}`} class="latest-link">
              <span class="latest-title">{article.data.title}</span>
              <div class="latest-meta">
                {article.data.category && (
                  <span class="latest-cat">{article.data.category}</span>
                )}
                <time class="latest-date" datetime={new Date(article.data.date).toISOString()}>
                  {new Date(article.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
              </div>
            </a>
          </li>
        ))}
      </ul>
      <a href="/reviews" class="view-all-link">View all reviews &rarr;</a>
    </aside>

    <!-- ── CENTER COLUMN: Hero + Subscribe + Rankings ─ -->
    <main class="col-center">

      <!-- Featured Hero -->
      {featuredArticle && (
        <section class="hero-card" style={`background: ${fGradient};`}>
          <div class="hero-eyebrow">
            <span class="hero-dot"></span>
            <span>Top Rated</span>
            {featuredArticle.data.category && (
              <span class="hero-cat">{featuredArticle.data.category}</span>
            )}
          </div>
          <a href={`/${featuredArticle.slug}`} class="hero-title-link">
            <h1 class="hero-title">{featuredArticle.data.title}</h1>
          </a>
          {featuredArticle.data.description && (
            <p class="hero-desc">{featuredArticle.data.description}</p>
          )}
          <div class="hero-footer">
            <div class="hero-footer-left">
              <time class="hero-date" datetime={new Date(featuredArticle.data.date).toISOString()}>
                {new Date(featuredArticle.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>
              {featuredArticle.data.winner && (
                <span class="hero-winner">Winner: <strong>{featuredArticle.data.winner}</strong></span>
              )}
            </div>
            <a href={`/${featuredArticle.slug}`} class="hero-read-btn">Read review &rarr;</a>
          </div>
          {featuredArticle.data.score && (
            <div class="hero-score">
              <span class="hero-score-val">{featuredArticle.data.score.toFixed(1)}</span>
              <span class="hero-score-max">/10</span>
            </div>
          )}
        </section>
      )}

      <!-- Subscribe Strip -->
      <section class="subscribe-strip">
        <div class="subscribe-copy">
          <p class="subscribe-headline">Hosting picks tested for real uptime. No sponsored rankings.</p>
        </div>
        <form class="subscribe-form" id="subscribe-form" action={API_URL} method="POST" novalidate>
          <input type="hidden" name="site_id" value={SITE_ID} />
          <div class="subscribe-row">
            <input
              class="subscribe-input"
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              autocomplete="email"
            />
            <button class="subscribe-btn" type="submit">Subscribe</button>
          </div>
          <p class="subscribe-fine">No spam. Unsubscribe any time.</p>
        </form>
      </section>

      <!-- Ranked Reviews -->
      {rankedArticles.length > 0 && (
        <section class="rankings-section">
          <div class="section-header">
            <span class="section-label">Rankings</span>
            <div class="section-line"></div>
          </div>
          <div class="rankings-grid">
            {rankedArticles.map((article, i) => (
              <div class="article-animate" style={`animation-delay: ${i * 60}ms`}>
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  author={article.data.author}
                  image={article.data.image}
                  category={article.data.category}
                  slug={article.slug}
                  score={article.data.score}
                  badge={article.data.badge}
                  rank={i + 2}
                />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- More Reviews -->
      {remainingArticles.length > 0 && (
        <section class="more-section">
          <div class="section-header">
            <span class="section-label">More Reviews</span>
            <div class="section-line"></div>
          </div>
          <div class="more-grid">
            {remainingArticles.map((article, i) => (
              <div class="article-animate" style={`animation-delay: ${i * 60}ms`}>
                <ArticleCard
                  title={article.data.title}
                  description={article.data.description}
                  date={article.data.date}
                  author={article.data.author}
                  image={article.data.image}
                  category={article.data.category}
                  slug={article.slug}
                  score={article.data.score}
                  badge={article.data.badge}
                />
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Methodology CTA -->
      <section class="methodology-cta">
        <div class="methodology-inner">
          <span class="methodology-label">Our Promise</span>
          <h2>Every score is earned,<br/><em>never paid for.</em></h2>
          <p>Every host is tested for real uptime, speed, and support. Not vendor-supplied SLA numbers.</p>
          <a href="/disclosure" class="methodology-link">Read our full methodology &rarr;</a>
        </div>
      </section>

    </main>

    <!-- ── RIGHT COLUMN: Top Hosting Picks ─────────── -->
    <aside class="col-right">
      <div class="picks-panel">
        <div class="panel-header">
          <span class="panel-label">Top hosts</span>
        </div>
        <ul class="picks-list">
          {TOP_PICKS.map((pick) => (
            <li class="pick-item">
              <a href={`/go/${pick.slug}`} class="pick-link" target="_blank" rel="nofollow noopener">
                <div class="pick-top">
                  <span class="pick-name">{pick.name}</span>
                  {pick.tag && (
                    <span class="pick-tag">{pick.tag}</span>
                  )}
                </div>
                <div class="pick-bottom">
                  <span class="pick-category">{pick.category}</span>
                  <span class="pick-price">{pick.price}</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
        <p class="picks-disclaimer">
          Affiliate links fund our testing. Rankings are never sold.
        </p>
      </div>
    </aside>

  </div>
</BaseLayout>

<script>
  const form = document.getElementById('subscribe-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[type="email"]') as HTMLInputElement;
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (!input || !btn) return;
      const email = input.value.trim();
      if (!email) return;
      btn.disabled = true;
      btn.textContent = 'Subscribing…';
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, site_id: 'hosthive' }),
        });
        if (res.ok) {
          btn.textContent = 'Subscribed!';
          input.value = '';
          btn.style.background = 'var(--emerald, #10b981)';
        } else {
          btn.textContent = 'Try again';
          btn.disabled = false;
        }
      } catch {
        btn.textContent = 'Try again';
        btn.disabled = false;
      }
    });
  }
</script>

<style>
  /* ── 3-Column Layout ─────────────────────────────── */
  .three-col-wrapper {
    display: grid;
    grid-template-columns: 220px 1fr 220px;
    grid-template-areas: "left center right";
    gap: var(--space-2xl);
    max-width: var(--max-width, 1280px);
    margin: 0 auto;
    padding: var(--space-2xl) 0 var(--space-4xl);
    align-items: start;
  }

  .col-left  { grid-area: left; }
  .col-center { grid-area: center; min-width: 0; }
  .col-right { grid-area: right; }

  /* ── Panel Headers ───────────────────────────────── */
  .panel-header {
    border-bottom: 2px solid var(--ink-950);
    padding-bottom: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .panel-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-950);
  }

  /* ── Left: Latest Reviews ────────────────────────── */
  .col-left {
    position: sticky;
    top: var(--space-xl, 1.5rem);
  }

  .latest-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .latest-item {
    border-bottom: 1px solid var(--ink-100);
  }

  .latest-link {
    display: block;
    padding: var(--space-sm) 0;
    text-decoration: none;
    transition: opacity var(--duration-fast, 150ms) ease;
  }

  .latest-link:hover { opacity: 0.75; }

  .latest-title {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-950);
    line-height: 1.35;
    margin-bottom: 0.25rem;
  }

  .latest-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .latest-cat {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--electric, #8b5cf6);
  }

  .latest-date {
    font-size: 0.7rem;
    color: var(--ink-400);
  }

  .view-all-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--electric, #8b5cf6);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-fast, 150ms) ease;
  }

  .view-all-link:hover { border-color: var(--electric, #8b5cf6); }

  /* ── Hero Card ───────────────────────────────────── */
  .hero-card {
    position: relative;
    border-radius: var(--border-radius-lg, 12px);
    padding: var(--space-2xl) var(--space-2xl) var(--space-xl);
    margin-bottom: var(--space-2xl);
    overflow: hidden;
    color: white;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.6);
    margin-bottom: var(--space-md);
  }

  .hero-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #a78bfa;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

  .hero-cat {
    background: rgba(255,255,255,0.1);
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    font-size: 0.65rem;
  }

  .hero-title-link { text-decoration: none; }

  .hero-title {
    font-size: clamp(1.5rem, 2.8vw, 2.25rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: white;
    margin: 0 0 var(--space-md);
    transition: opacity var(--duration-fast, 150ms) ease;
  }

  .hero-title-link:hover .hero-title { opacity: 0.85; }

  .hero-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    margin-bottom: var(--space-xl);
    max-width: 520px;
  }

  .hero-footer {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero-footer-left {
    display: flex;
    flex-direction: column;
    gap: 3px;
    flex: 1;
    min-width: 0;
  }

  .hero-date {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
  }

  .hero-winner {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.65);
  }

  .hero-winner strong { color: white; font-weight: 700; }

  .hero-read-btn {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 6px;
    color: white;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background var(--duration-fast, 150ms) ease;
    flex-shrink: 0;
  }

  .hero-read-btn:hover { background: rgba(255,255,255,0.25); color: white; }

  .hero-score {
    position: absolute;
    top: var(--space-xl);
    right: var(--space-2xl);
    display: flex;
    align-items: flex-end;
    gap: 2px;
    opacity: 0.25;
  }

  .hero-score-val {
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 1;
    letter-spacing: -0.04em;
    color: white;
  }

  .hero-score-max {
    font-size: 1.25rem;
    color: white;
    margin-bottom: 0.75rem;
  }

  /* ── Subscribe Strip ─────────────────────────────── */
  .subscribe-strip {
    background: var(--ink-50, #f9f9f9);
    border: 1px solid var(--ink-100);
    border-left: 3px solid var(--electric, #8b5cf6);
    border-radius: 8px;
    padding: var(--space-lg) var(--space-xl);
    margin-bottom: var(--space-2xl);
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .subscribe-copy { flex: 1; min-width: 180px; }

  .subscribe-headline {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ink-700);
    margin: 0;
    line-height: 1.4;
  }

  .subscribe-form { flex: 1; min-width: 240px; }

  .subscribe-row {
    display: flex;
    gap: 0.5rem;
  }

  .subscribe-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--ink-200);
    border-radius: 6px;
    font-size: 0.875rem;
    background: white;
    color: var(--ink-950);
    outline: none;
    transition: border-color var(--duration-fast, 150ms) ease;
  }

  .subscribe-input:focus { border-color: var(--electric, #8b5cf6); }

  .subscribe-btn {
    padding: 0.5rem 1rem;
    background: var(--electric, #8b5cf6);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity var(--duration-fast, 150ms) ease;
  }

  .subscribe-btn:hover { opacity: 0.85; }
  .subscribe-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .subscribe-fine {
    font-size: 0.7rem;
    color: var(--ink-400);
    margin: 0.35rem 0 0;
  }

  /* ── Section Headers ─────────────────────────────── */
  .section-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-400);
    white-space: nowrap;
  }

  .section-line { flex: 1; height: 1px; background: var(--ink-100); }

  /* ── Rankings Grid ───────────────────────────────── */
  .rankings-section { margin-bottom: var(--space-3xl); }

  .rankings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  .article-animate {
    animation: fadeInUp var(--duration-slow, 400ms) var(--ease-out, ease-out) both;
  }

  /* ── More Reviews ────────────────────────────────── */
  .more-section { margin-bottom: var(--space-3xl); }

  .more-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  /* ── Methodology CTA ─────────────────────────────── */
  .methodology-cta { margin: var(--space-3xl) 0 0; }

  .methodology-inner {
    padding: var(--space-3xl) 0;
    border-top: 2px solid var(--ink-950);
  }

  .methodology-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-400);
  }

  .methodology-inner h2 {
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
  }

  .methodology-inner h2 em { font-style: italic; color: var(--ink-500); }
  .methodology-inner p { color: var(--ink-500); max-width: 520px; line-height: 1.7; }

  .methodology-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--ink-950);
    text-decoration: none;
    border-bottom: 1.5px solid var(--ink-950);
    padding-bottom: 2px;
    transition: opacity var(--duration-fast, 150ms) ease;
  }

  .methodology-link:hover { opacity: 0.65; }

  /* ── Right: Picks Panel ──────────────────────────── */
  .col-right {
    position: sticky;
    top: var(--space-xl, 1.5rem);
  }

  .picks-panel {
    background: var(--surface, #fff);
    border: 1px solid var(--ink-100);
    border-radius: 10px;
    padding: var(--space-lg);
  }

  .picks-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pick-item {
    border-bottom: 1px solid var(--ink-100);
  }

  .pick-item:last-child { border-bottom: none; }

  .pick-link {
    display: block;
    padding: var(--space-sm) 0;
    text-decoration: none;
    transition: opacity var(--duration-fast, 150ms) ease;
  }

  .pick-link:hover { opacity: 0.75; }

  .pick-top {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 3px;
  }

  .pick-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--ink-950);
  }

  .pick-tag {
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    background: rgba(139, 92, 246, 0.12);
    color: var(--electric, #8b5cf6);
    white-space: nowrap;
  }

  .pick-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .pick-category {
    font-size: 0.68rem;
    color: var(--ink-400);
  }

  .pick-price {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--electric, #8b5cf6);
  }

  .picks-disclaimer {
    margin: var(--space-md) 0 0;
    font-size: 0.65rem;
    color: var(--ink-400);
    line-height: 1.4;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 1100px) {
    .three-col-wrapper {
      grid-template-columns: 200px 1fr 200px;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 900px) {
    .three-col-wrapper {
      grid-template-columns: 1fr;
      grid-template-areas:
        "center"
        "right"
        "left";
      gap: var(--space-2xl);
    }

    .col-left, .col-right { position: static; }

    .picks-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
    }

    .subscribe-strip { flex-direction: column; gap: var(--space-md); }
  }

  @media (max-width: 600px) {
    .three-col-wrapper { padding: var(--space-xl) 0 var(--space-3xl); }

    .hero-card { padding: var(--space-xl) var(--space-lg) var(--space-lg); }
    .hero-score { display: none; }

    .rankings-grid, .more-grid { grid-template-columns: 1fr; }

    .picks-list { grid-template-columns: 1fr; }

    .subscribe-row { flex-direction: column; }
    .subscribe-btn { width: 100%; }
  }
</style>
