---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Terms of Service" description="HostHive terms of service.">
  <div class="container"><div class="lp">
    <h1>Terms of Service</h1><p class="u">Last updated: April 2026</p>
    <section><h2>Acceptance</h2><p>By using HostHive (host-hive.net), you agree to these terms.</p></section>
    <section><h2>Content Accuracy</h2><p>We strive for accurate reviews but hosting features and pricing change frequently. Verify details with the provider before purchasing.</p></section>
    <section><h2>Affiliate Relationships</h2><p>We earn commissions through affiliate links. This doesn't affect pricing or our editorial independence. See our <a href="/disclosure">Affiliate Disclosure</a>.</p></section>
    <section><h2>Intellectual Property</h2><p>All content is owned by HostHive and protected by copyright.</p></section>
    <section><h2>Contact</h2><p>Email <a href="mailto:info@host-hive.net">info@host-hive.net</a>.</p></section>
  </div></div>
</BaseLayout>
<style>.lp{max-width:700px;margin:0 auto;padding:3rem 0}.lp h1{font-size:2.5rem;margin-bottom:.5rem}.u{color:#6b7280;font-size:.9rem;margin-bottom:2rem}.lp section{margin-bottom:2rem}.lp h2{font-size:1.3rem;margin-bottom:.75rem;color:#f59e0b}.lp p{color:#d1d8e0;line-height:1.8}</style>
