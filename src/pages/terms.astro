---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Service" description="HostHive terms of service.">
  <article class="legal-page">
    <span class="page-label">Legal</span>
    <h1>Terms of Service</h1>
    <p class="updated">Last updated: April 2026</p>

    <section>
      <h2>Acceptance</h2>
      <p>By using HostHive (host-hive.net), you agree to these terms.</p>
    </section>

    <section>
      <h2>Content Accuracy</h2>
      <p>We strive for accurate reviews but hosting features and pricing change frequently. Verify details with the provider before purchasing.</p>
    </section>

    <section>
      <h2>Affiliate Relationships</h2>
      <p>We earn commissions through affiliate links. This doesn't affect pricing or our editorial independence. See our <a href="/disclosure">Affiliate Disclosure</a>.</p>
    </section>

    <section>
      <h2>Intellectual Property</h2>
      <p>All content is owned by HostHive and protected by copyright.</p>
    </section>

    <section>
      <h2>Contact</h2>
      <p>Email <a href="mailto:info@host-hive.net">info@host-hive.net</a>.</p>
    </section>
  </article>
</BaseLayout>

<style>
  .legal-page { max-width: var(--max-width); margin: 0 auto; padding: var(--space-3xl) 0; }
  .page-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-400); display: block; margin-bottom: var(--space-sm); }
  .legal-page h1 { margin-bottom: var(--space-sm); }
  .updated { color: var(--ink-400); font-size: 0.85rem; margin-bottom: var(--space-2xl); }
  .legal-page section { margin-bottom: var(--space-2xl); }
  .legal-page h2 { font-size: 1.5rem; margin-bottom: var(--space-md); margin-top: 0; }
  .legal-page p { color: var(--ink-700); line-height: 1.8; }
  .legal-page a { color: var(--violet); }
  .legal-page a:hover { color: var(--violet-hover); }
</style>
