---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="nf">
    <h1>404</h1>
    <p>The page you're looking for doesn't exist.</p>
    <a href="/" class="nf-link">Back to Home &rarr;</a>
  </div>
</BaseLayout>

<style>
  .nf { text-align: center; padding: var(--space-4xl) var(--space-lg); max-width: var(--max-width); margin: 0 auto; }
  .nf h1 { font-family: var(--font-display); font-size: 6rem; color: var(--ink-200); margin-bottom: var(--space-md); }
  .nf p { font-size: 1.1rem; color: var(--ink-500); margin-bottom: var(--space-xl); }
  .nf-link { display: inline-block; font-size: 0.9rem; font-weight: 600; color: var(--ink-950); text-decoration: none; border-bottom: 1.5px solid var(--ink-950); padding-bottom: 2px; transition: opacity var(--duration-fast) var(--ease-out); }
  .nf-link:hover { opacity: 0.7; color: var(--ink-950); }
</style>
