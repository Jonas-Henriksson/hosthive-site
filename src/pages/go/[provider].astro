---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const providers = [
    { provider: 'bluehost', name: 'Bluehost', url: 'https://bluehost.sjv.io/c/7170259/1376228/11352' },
    { provider: 'siteground', name: 'SiteGround', url: 'https://siteground.com' },
    { provider: 'hostinger', name: 'Hostinger', url: 'https://hostinger.com' },
    { provider: 'cloudways', name: 'Cloudways', url: 'https://www.cloudways.com/en/?id=2152386' },
    { provider: 'wpengine', name: 'WP Engine', url: 'https://wpengine.com' },
    { provider: 'kinsta', name: 'Kinsta', url: 'https://kinsta.com/wordpress-hosting/?kaid=ZIGESENFSZNM' },
    { provider: 'kinsta-apps', name: 'Kinsta Application Hosting', url: 'https://kinsta.com/application-hosting/?kaid=ZIGESENFSZNM' },
    { provider: 'kinsta-woo', name: 'Kinsta WooCommerce Hosting', url: 'https://kinsta.com/wordpress-hosting/woocommerce/?kaid=ZIGESENFSZNM' },
    { provider: 'contabo', name: 'Contabo COM', url: 'https://www.kqzyfj.com/click-101724886-13796479-1713463956000' },
    { provider: 'protonvpn', name: 'ProtonVPN', url: 'https://www.jdoqocy.com/click-101724886-15834536-1774304322000' },
    { provider: 'iolo', name: 'iolo System Mechanic', url: 'https://www.jdoqocy.com/click-101724886-10783204-1749144832000' },
    { provider: 'gandi', name: 'Gandi', url: 'https://www.jdoqocy.com/click-101724886-17236097-1771548948000' },
    { provider: 'turbify', name: 'Turbify', url: 'https://www.jdoqocy.com/click-101724886-17008695-1763520800000' },
    { provider: 'sucuri', name: 'Sucuri', url: 'https://www.jdoqocy.com/click-101724886-13942195-1579567117000' },
    { provider: 'elementor', name: 'Elementor', url: 'https://www.dpbolvw.net/click-101724886-15891275-1740188742000' },
    { provider: 'hostpapa', name: 'Hostpapa', url: 'https://www.kqzyfj.com/click-101724886-10513989-1626390665000' },
    { provider: 'dynadot', name: 'Dynadot.com', url: 'https://www.tkqlhce.com/click-101724886-12589508-1673418767000' },
  ];
  return providers.map((p) => ({
    params: { provider: p.provider },
    props: { name: p.name, url: p.url },
  }));
}

const { name, url } = Astro.props;
---

<BaseLayout title={`Visit ${name}`} description={`Redirecting to ${name} - recommended by HostHive`}>
  <div class="redirect-page">
    <h1>Redirecting to {name}...</h1>
    <p>If you're not redirected automatically, <a href={url} rel="nofollow sponsored">click here</a>.</p>
    <p class="disclosure">HostHive may earn a commission if you sign up. This doesn't affect our reviews.</p>
  </div>
</BaseLayout>

<script define:vars={{ url }}>
  setTimeout(() => { window.location.href = url; }, 1500);
</script>

<style>
  .redirect-page { text-align: center; padding: var(--space-4xl) var(--space-lg); max-width: var(--max-width); margin: 0 auto; }
  .redirect-page h1 { font-size: 1.75rem; color: var(--ink-950); margin-bottom: var(--space-md); }
  .redirect-page p { color: var(--ink-500); margin-bottom: var(--space-md); }
  .redirect-page a { color: var(--violet); }
  .disclosure { font-size: 0.85rem; color: var(--ink-400); margin-top: var(--space-xl); }
</style>
