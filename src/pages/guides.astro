---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => !data.draft);
const guides = articles.filter((a) => {
  const t = a.data.title.toLowerCase();
  return t.includes('guide') || t.includes('how to') || t.includes('explained') || t.includes('what is') || t.includes('tips') || t.includes('checklist');
}).sort((a, b) => {
  const scoreA = a.data.score || 0;
  const scoreB = b.data.score || 0;
  if (scoreB !== scoreA) return scoreB - scoreA;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<BaseLayout title="Hosting Guides" description="Web hosting guides and tutorials. Learn about hosting types, migration, optimization, and more.">
  <div class="page-wrapper">
    <div class="page-header">
      <span class="page-label">Guides</span>
      <h1>Everything hosting,<br/><em>explained clearly.</em></h1>
      <p>In-depth guides to help you make the right hosting decisions.</p>
    </div>
    <div class="articles-grid">
      {guides.map((article, i) => (
        <div class="article-animate" style={`animation-delay: ${i * 50}ms`}>
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            date={article.data.date}
            author={article.data.author}
            category={article.data.category}
            slug={article.slug}
            score={article.data.score}
            badge={article.data.badge}
          />
        </div>
      ))}
    </div>
    {guides.length === 0 && <p class="empty-state">No guides yet. Check back soon.</p>}
  </div>
</BaseLayout>

<style>
  .page-wrapper { max-width: var(--max-width-wide); margin: 0 auto; }
  .page-header { padding: var(--space-3xl) 0 var(--space-2xl); border-bottom: 1px solid var(--ink-100); margin-bottom: var(--space-2xl); }
  .page-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-400); }
  .page-header h1 { margin-top: var(--space-sm); margin-bottom: var(--space-sm); }
  .page-header h1 em { font-style: italic; color: var(--ink-500); }
  .page-header p { color: var(--ink-500); font-size: 1.05rem; margin-bottom: 0; }
  .articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: var(--space-lg); padding-bottom: var(--space-3xl); }
  .article-animate { animation: fadeInUp var(--duration-slow) var(--ease-out) both; }
  .empty-state { text-align: center; color: var(--ink-400); padding: var(--space-3xl) 0; font-size: 1.05rem; }
  @media (max-width: 768px) { .articles-grid { grid-template-columns: 1fr; } }
</style>
