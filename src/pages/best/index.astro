---
import BaseLayout from '../../layouts/BaseLayout.astro';
import siteConfig from '../../site.config';

const pageTitle = `Best Web Hosting Guides 2026 — ${siteConfig.siteName}`;
const pageDesc = `Browse all "best for" guides on ${siteConfig.siteName}. Find the perfect web hosting for your specific needs.`;
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <div class="best-index">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span class="current">Best-For Guides</span>
    </nav>

    <header class="page-header">
      <span class="page-label">15 guides</span>
      <h1>Best Web Hosting Guides</h1>
      <p class="page-subtitle">Find the perfect web hosting for your specific needs. Each guide is curated from our expert-tested reviews.</p>
      <div class="header-rule"></div>
    </header>

    <div class="best-grid">
      <a href="/best/web-hosting-for-wordpress" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Wordpress</span></a>
        <a href="/best/web-hosting-for-ecommerce" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Ecommerce</span></a>
        <a href="/best/web-hosting-for-beginners" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Beginners</span></a>
        <a href="/best/web-hosting-for-developers" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Developers</span></a>
        <a href="/best/web-hosting-for-small-business" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Small Business</span></a>
        <a href="/best/web-hosting-for-agencies" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Agencies</span></a>
        <a href="/best/web-hosting-for-bloggers" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Bloggers</span></a>
        <a href="/best/web-hosting-for-high-traffic" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">High Traffic</span></a>
        <a href="/best/web-hosting-for-budget" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Budget</span></a>
        <a href="/best/web-hosting-for-managed" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Managed</span></a>
        <a href="/best/web-hosting-for-vps" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Vps</span></a>
        <a href="/best/web-hosting-for-dedicated" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Dedicated</span></a>
        <a href="/best/web-hosting-for-django" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Django</span></a>
        <a href="/best/web-hosting-for-nodejs" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Nodejs</span></a>
        <a href="/best/web-hosting-for-staging" class="best-link"><span class="best-label">Best Web Hosting for</span><span class="best-uc">Staging</span></a>
    </div>
  </div>
</BaseLayout>

<style>
  .best-index {
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--ink-400);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb a { color: var(--ink-500); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink-950); }
  .sep { color: var(--ink-300); }
  .current { color: var(--ink-400); }

  .page-header { margin-bottom: var(--space-2xl); }

  .page-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-400);
  }

  .page-header h1 {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .page-subtitle {
    font-size: 1rem;
    color: var(--ink-500);
    margin-bottom: var(--space-md);
  }

  .header-rule {
    height: 2px;
    width: 48px;
    background: var(--surface-inverse);
  }

  .best-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }

  .best-link {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
    border: 1px solid var(--ink-100);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-out);
    background: var(--surface);
  }

  .best-link:hover {
    border-color: var(--ink-300);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .best-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-400);
  }

  .best-uc {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--ink-950);
    margin-top: 0.25rem;
    letter-spacing: -0.02em;
  }

  .best-link:hover .best-uc {
    color: var(--electric);
  }

  @media (max-width: 768px) {
    .best-grid { grid-template-columns: 1fr; }
  }
</style>
