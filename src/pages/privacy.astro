---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy" description="HostHive privacy policy.">
  <article class="legal-page">
    <span class="page-label">Legal</span>
    <h1>Privacy Policy</h1>
    <p class="updated">Last updated: April 2026</p>

    <section>
      <h2>Information We Collect</h2>
      <p>HostHive is a static website. We do not require accounts or collect personal information. Standard web server logs may record your IP address and browser type.</p>
    </section>

    <section>
      <h2>Cookies</h2>
      <p>We may use cookies for basic functionality. Cloudflare (our host) may set its own cookies. We do not use advertising cookies.</p>
    </section>

    <section>
      <h2>Affiliate Links</h2>
      <p>Our site contains affiliate links. When you click them, the hosting provider may collect information per their own privacy policy.</p>
    </section>

    <section>
      <h2>Contact</h2>
      <p>Questions? Email <a href="mailto:info@host-hive.net">info@host-hive.net</a>.</p>
    </section>
  </article>
</BaseLayout>

<style>
  .legal-page { max-width: var(--max-width); margin: 0 auto; padding: var(--space-3xl) 0; }
  .page-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-400); display: block; margin-bottom: var(--space-sm); }
  .legal-page h1 { margin-bottom: var(--space-sm); }
  .updated { color: var(--ink-400); font-size: 0.85rem; margin-bottom: var(--space-2xl); }
  .legal-page section { margin-bottom: var(--space-2xl); }
  .legal-page h2 { font-size: 1.5rem; margin-bottom: var(--space-md); margin-top: 0; }
  .legal-page p { color: var(--ink-700); line-height: 1.8; }
  .legal-page a { color: var(--violet); }
  .legal-page a:hover { color: var(--violet-hover); }
</style>
