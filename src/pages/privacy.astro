---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy Policy" description="HostHive privacy policy.">
  <div class="container"><div class="lp">
    <h1>Privacy Policy</h1><p class="u">Last updated: April 2026</p>
    <section><h2>Information We Collect</h2><p>HostHive is a static website. We do not require accounts or collect personal information. Standard web server logs may record your IP address and browser type.</p></section>
    <section><h2>Cookies</h2><p>We may use cookies for basic functionality. Cloudflare (our host) may set its own cookies. We do not use advertising cookies.</p></section>
    <section><h2>Affiliate Links</h2><p>Our site contains affiliate links. When you click them, the hosting provider may collect information per their own privacy policy.</p></section>
    <section><h2>Contact</h2><p>Questions? Email <a href="mailto:info@host-hive.net">info@host-hive.net</a>.</p></section>
  </div></div>
</BaseLayout>
<style>.lp{max-width:700px;margin:0 auto;padding:3rem 0}.lp h1{font-size:2.5rem;margin-bottom:.5rem}.u{color:#6b7280;font-size:.9rem;margin-bottom:2rem}.lp section{margin-bottom:2rem}.lp h2{font-size:1.3rem;margin-bottom:.75rem;color:#f59e0b}.lp p{color:#d1d8e0;line-height:1.8}</style>
