---
import { siteConfig } from '../site.config';

interface Props {
  title: string;
  description?: string;
  structuredData?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description = siteConfig.description,
  structuredData,
} = Astro.props;

const fullTitle = `${title} | ${siteConfig.name}`;
const canonicalUrl = `${siteConfig.url}${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content={siteConfig.keywords} />
  <meta name="author" content={siteConfig.author} />

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={siteConfig.og.image} />
  <meta property="og:type" content={siteConfig.og.type} />
  <meta property="og:url" content={canonicalUrl} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />

  <link rel="canonical" href={canonicalUrl} />

  {structuredData && (
    Array.isArray(structuredData)
      ? structuredData.map((sd) => <script type="application/ld+json" set:html={JSON.stringify(sd)} />)
      : <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <title>{fullTitle}</title>

  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { font-family: 'Inter', sans-serif; scroll-behavior: smooth; }
    body { background-color: #0f1117; color: #e4e9f0; line-height: 1.6; }

    h1 { font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; color: #ffffff; line-height: 1.2; }
    h2 { font-size: 2rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; color: #ffffff; }
    h3 { font-size: 1.5rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.75rem; color: #ffffff; }
    h4, h5, h6 { font-weight: 600; margin-top: 1rem; margin-bottom: 0.5rem; color: #ffffff; }
    p { margin-bottom: 1rem; font-size: 1rem; color: #d1d8e0; }
    a { color: #f59e0b; text-decoration: none; transition: color 0.3s ease; }
    a:hover { color: #d97706; }
    button { font-family: inherit; }
    ul, ol { margin-left: 2rem; margin-bottom: 1rem; }
    li { margin-bottom: 0.5rem; }

    code { background-color: #1a1d2b; color: #f59e0b; padding: 0.2rem 0.5rem; border-radius: 0.25rem; font-family: 'Monaco', monospace; font-size: 0.9em; }
    pre { background-color: #1a1d2b; padding: 1.5rem; border-radius: 0.5rem; overflow-x: auto; margin-bottom: 1rem; border-left: 4px solid #f59e0b; }
    blockquote { border-left: 4px solid #f59e0b; padding-left: 1.5rem; margin-left: 0; margin-bottom: 1rem; color: #a8b3bf; font-style: italic; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    nav { background-color: #0a0c12; border-bottom: 1px solid #1a1d2b; position: sticky; top: 0; z-index: 100; }
    nav .container { display: flex; justify-content: space-between; align-items: center; height: 70px; }
    .nav-logo { font-size: 1.5rem; font-weight: 700; background: linear-gradient(135deg, #f59e0b 0%, #ef4444 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { color: #d1d8e0; font-weight: 500; transition: color 0.3s ease; }
    .nav-links a:hover { color: #f59e0b; }

    footer { background-color: #0a0c12; border-top: 1px solid #1a1d2b; margin-top: 4rem; padding: 3rem 0; }
    footer .container { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-bottom: 2rem; }
    footer h4 { font-size: 1rem; margin-bottom: 1rem; }
    footer a { display: block; margin-bottom: 0.5rem; color: #a8b3bf; }
    footer a:hover { color: #f59e0b; }

    .footer-bottom { border-top: 1px solid #1a1d2b; padding-top: 2rem; text-align: center; color: #6b7280; font-size: 0.9rem; }

    .affiliate-disclosure { background-color: #1a1d2b; border-left: 4px solid #f59e0b; padding: 1rem; margin-bottom: 2rem; border-radius: 0.25rem; font-size: 0.9rem; color: #a8b3bf; }

    main { min-height: calc(100vh - 70px); padding: 2rem 0; }

    @media (max-width: 768px) {
      h1 { font-size: 1.875rem; }
      h2 { font-size: 1.5rem; }
      h3 { font-size: 1.25rem; }
      .nav-links { gap: 1rem; font-size: 0.9rem; }
      footer .container { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <nav>
    <div class="container">
      <a href="/" class="nav-logo">{siteConfig.logo}</a>
      <ul class="nav-links">
        {siteConfig.nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>
  </nav>

  <main><slot /></main>

  <footer>
    <div class="container">
      <div>
        <h4>About HostHive</h4>
        <p>Independent hosting reviews and comparisons to help you find the perfect web hosting for your needs.</p>
      </div>
      <div>
        <h4>Quick Links</h4>
        <a href="/">Home</a>
        <a href="/reviews">Reviews</a>
        <a href="/comparisons">Comparisons</a>
        <a href="/guides">Guides</a>
      </div>
      <div>
        <h4>Legal</h4>
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="/disclosure">Affiliate Disclosure</a>
      </div>
    </div>

    <div class="container">
      <div class="affiliate-disclosure">
        <strong>Affiliate Disclosure:</strong> HostHive earns commissions from hosting providers when you purchase through our links. This doesn't affect our ratings or reviews — we recommend only hosts we've tested and trust.
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved. | {siteConfig.email}</p>
    </div>
  </footer>
</body>
</html>
