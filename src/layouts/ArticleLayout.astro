---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  author?: string;
  updated?: Date;
  affiliateLinks?: Array<{ host: string; url: string }>;
}

const {
  title, description, date, category,
  author = 'HostHive Team',
  updated,
  affiliateLinks = [],
} = Astro.props;

const formatDate = (d: Date) => new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);

const categoryColors: Record<string, string> = {
  wordpress: '#6366f1',
  shared: '#f59e0b',
  vps: '#10b981',
  cloud: '#06b6d4',
  dedicated: '#ef4444',
  ecommerce: '#ec4899',
  managed: '#8b5cf6',
  budget: '#84cc16',
};

const categoryColor = categoryColors[category] || '#f59e0b';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: 'https://host-hive.net/og-image.png',
  datePublished: date.toISOString(),
  dateModified: updated?.toISOString() || date.toISOString(),
  author: { '@type': 'Organization', name: 'HostHive' },
};
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <article class="article-container">
    <div class="article-header">
      <div class="container">
        <div class="breadcrumb">
          <a href="/">Home</a><span>/</span><a href="/reviews">Reviews</a><span>/</span><span>{title}</span>
        </div>
        <h1>{title}</h1>
        <p class="article-meta">
          By {author} | {formatDate(date)}
          {updated && <span> | Updated {formatDate(updated)}</span>}
        </p>
        <div class="category-badge" style={`background-color: ${categoryColor}20; border-left: 4px solid ${categoryColor}`}>
          <span class="category-label" style={`color: ${categoryColor}`}>{category.charAt(0).toUpperCase() + category.slice(1)}</span>
        </div>
      </div>
    </div>

    <div class="article-content">
      <div class="container">
        <div class="content-wrapper">
          <div class="main-content"><slot /></div>
          <aside class="sidebar">
            {affiliateLinks.length > 0 && (
              <div class="affiliate-box">
                <h3>Quick Links</h3>
                <div class="affiliate-buttons">
                  {affiliateLinks.map((link) => (
                    <a href={link.url} class="cta-button" target="_blank" rel="noopener noreferrer">Visit {link.host}</a>
                  ))}
                </div>
              </div>
            )}
            <div class="info-box">
              <h4>About This Review</h4>
              <p>HostHive reviews are based on hands-on testing, uptime monitoring, speed benchmarks, and support evaluation. Our recommendations are independent of affiliate relationships.</p>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </article>

  <style is:global>
    .article-container { background-color: #0f1117; }
    .article-header { background: linear-gradient(135deg, #0f1117 0%, #1a1d2b 100%); border-bottom: 1px solid #1a1d2b; padding: 3rem 0; margin-bottom: 3rem; }
    .breadcrumb { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; font-size: 0.9rem; color: #a8b3bf; }
    .breadcrumb a { color: #f59e0b; }
    .article-header h1 { margin-bottom: 1rem; max-width: 900px; }
    .article-meta { color: #a8b3bf; font-size: 0.95rem; margin-bottom: 1.5rem; }
    .category-badge { display: inline-block; padding: 0.5rem 1rem; border-radius: 0.25rem; margin-bottom: 1rem; }
    .category-label { font-weight: 600; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; }

    .content-wrapper { display: grid; grid-template-columns: 1fr 300px; gap: 3rem; }
    .main-content { line-height: 1.8; font-size: 1.05rem; }
    .main-content p { margin-bottom: 1.5rem; color: #d1d8e0; }
    .main-content table { width: 100%; border-collapse: collapse; margin: 2rem 0; background-color: #1a1d2b; border-radius: 0.5rem; overflow: hidden; }
    .main-content th { background-color: #0f1117; color: #ffffff; padding: 1rem; text-align: left; font-weight: 600; border-bottom: 2px solid #f59e0b; }
    .main-content td { padding: 1rem; border-bottom: 1px solid #2d3748; }
    .main-content tr:last-child td { border-bottom: none; }
    .main-content strong { color: #ffffff; font-weight: 600; }
    .main-content em { color: #f59e0b; font-style: italic; }

    .sidebar { position: sticky; top: 90px; height: fit-content; }
    .affiliate-box, .info-box { background-color: #1a1d2b; border: 1px solid #2d3748; border-radius: 0.5rem; padding: 1.5rem; margin-bottom: 1.5rem; }
    .affiliate-box h3 { font-size: 1.1rem; margin-bottom: 1rem; color: #ffffff; }
    .affiliate-buttons { display: flex; flex-direction: column; gap: 0.75rem; }
    .cta-button { display: block; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: #ffffff; padding: 0.75rem 1rem; border-radius: 0.375rem; text-align: center; font-weight: 600; transition: all 0.3s ease; font-size: 0.9rem; }
    .cta-button:hover { background: linear-gradient(135deg, #d97706 0%, #b45309 100%); transform: translateY(-2px); box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3); color: #ffffff; }
    .info-box h4 { margin-top: 0; margin-bottom: 0.75rem; }
    .info-box p { font-size: 0.9rem; margin-bottom: 0; color: #a8b3bf; }

    @media (max-width: 768px) {
      .article-header { padding: 2rem 0; margin-bottom: 2rem; }
      .content-wrapper { grid-template-columns: 1fr; gap: 2rem; }
      .sidebar { position: static; }
      .main-content table { font-size: 0.9rem; }
      .main-content th, .main-content td { padding: 0.75rem; }
    }
  </style>
</BaseLayout>
